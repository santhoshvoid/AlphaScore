# ── Local development .env ────────────────────────────────────
# Copy this to .env in your project root.
# Never commit .env to GitHub (make sure it's in .gitignore).

# Local Redis (Docker)
REDIS_URL=redis://localhost:6379/0

# Supabase PostgreSQL
DATABASE_URL=your_supabase_connection_string_here

# Sentiment: false = use local FinBERT, true = use VADER
USE_VADER=false

# HuggingFace token (needed for local FinBERT download)
HF_TOKEN=your_hf_token_here

# NewsAPI (optional — sentiment news fetch)
NEWS_API_KEY=your_newsapi_key_here

# Email alerts (optional locally)
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_16char_app_password
